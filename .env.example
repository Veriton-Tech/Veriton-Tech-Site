# Environment Variables Example
# 
# For LOCAL DEVELOPMENT: Copy this to .env.local
# For DOCKER PRODUCTION: Copy this to .env
#
# Both files are gitignored for security

# Caddy Network Configuration (for Docker)
CADDY_NETWORK_NAME=hojaega-backend_hojaega_net

# Email Configuration (for contact form with nodemailer)
# Your Gmail address
EMAIL_USER=your-email@gmail.com

# Gmail App Password (NOT your regular password)
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_APP_PASSWORD=your_16_char_app_password

# Where to receive contact form emails (optional, defaults to EMAIL_USER)
EMAIL_RECEIVER=your-email@gmail.com

# Alternative: Use FormSubmit.co (comment out EMAIL_* vars above and uncomment below)
# NEXT_PUBLIC_FORMSUBMIT_EMAIL=your-email@example.com
